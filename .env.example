# Database (Neon PostgreSQL)
DATABASE_URL="your_database_url_here"

# API Key
API_KEY_SECRET=your_api_key_secret_here

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# App
PORT=4019
NODE_ENV=production
FRONTEND_URL=https://tatek.brightfitnessgym.com

# SMS (AfroMessage)
SMS_API_KEY=your_sms_api_key_here
SMS_SENDER_ID=your_sender_id
AFRO_TOKEN=your_afro_token
AFRO_SENDER_NAME=Tatek Gym
AFRO_IDENTIFIER_ID=your_identifier
AFRO_CALLBACK_BASE_URL=https://tatek.api.brightfitnessgym.com
